PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=*

HTTP_RATE_WINDOW_MS=60000
HTTP_RATE_MAX=160
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RATE_LIMIT_COUNT=25
MAX_MESSAGE_BYTES=4194304

# memory | redis | postgres
HISTORY_PROVIDER=memory
HISTORY_LIMIT=100

# Optional when HISTORY_PROVIDER=redis
REDIS_URL=redis://localhost:6379

# Optional when HISTORY_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat
PG_SSL=false
